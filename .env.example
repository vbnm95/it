DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
KRX_AUTH_KEY="YOUR_KRX_AUTH_KEY"
DART_API_KEY="YOUR_DART_API_KEY"

# KRX 문서 샘플 기준 기본값
# 승인 후 받은 문서에서 운영 base path 가 다르면 이 값만 수정
KRX_API_BASE="https://openapi.krx.co.kr/svc/sample/apis/sto"
DART_API_BASE="https://opendart.fss.or.kr/api"
REQUEST_TIMEOUT="30"
REQUEST_RETRIES="3"

